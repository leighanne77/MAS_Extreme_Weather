# MAS — sites.ttl : Step-3 ontology extension (extends risk.ttl).
# REAL reuse now (not prose):
#   - BFO hooks: rdfs:subClassOf real obo:BFO_* IRIs (ISO/IEC 21838-2 / BFO-2020)
#   - Ecological settings: real ENVO IRIs resolved via the EBI OLS4 API (2026-07-04)
#   - Investor/Defense: FIBO / DoDAF-DM2 cited as authority (+ seeAlso the standard)
#   - PROV-O: instances wasDerivedFrom the DIN site list (lineage nod, Step 4)
# T-Box + a demonstration A-Box (the 10 DIN sites' settings; two sites fully detailed).
# Base IRIs are placeholders. Alignment references BFO/ENVO IRIs WITHOUT owl:imports
# (lightweight alignment; import the full ontologies only if OWL reasoning is needed).

@prefix mas:     <https://mas.example/ontology/core#> .
@prefix reg-def: <https://mas.example/ontology/register/defense#> .
@prefix reg-eco: <https://mas.example/ontology/register/ecological#> .
@prefix reg-fin: <https://mas.example/ontology/register/financial#> .
@prefix ex:      <https://mas.example/instance/din-sites#> .
@prefix obo:     <http://purl.obolibrary.org/obo/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

##############################################################################
# CLASSES — each hooked to a REAL BFO-2020 superclass (the reuse-first backbone)
##############################################################################
mas:Asset a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;      # material entity
    rdfs:label "Real Asset" ;
    skos:definition "A physical real-asset site (facility). Hooked under BFO material entity." .

mas:Capability a owl:Class ; rdfs:subClassOf obo:BFO_0000016 ; # disposition
    rdfs:label "Capability" ; mas:authority "DoDAF/DM2 (Capability); MIL-STD-882" ;
    rdfs:seeAlso <https://dodcio.defense.gov/Library/DoD-Architecture-Framework/> ;
    skos:definition "A national/defense capability an asset provides — a disposition realized in activity." .

mas:Hazard a owl:Class ; rdfs:subClassOf obo:BFO_0000015 ;     # process
    rdfs:label "Hazard" ; mas:authority "IPCC AR6; NOAA; FEMA NRI" ;
    skos:definition "An extreme-weather / environmental hazard process threatening the asset." .

mas:EcosystemService a owl:Class ; rdfs:subClassOf obo:BFO_0000034 ;  # function
    rdfs:label "Ecosystem Service" ; mas:authority "CICES; IUCN; ECOCORE" ;
    skos:definition "An ecosystem function that buffers hazard (e.g. wave attenuation)." .

mas:NbS a owl:Class ; rdfs:subClassOf obo:BFO_0000040 ;        # material entity
    rdfs:label "Nature-based Solution" ; mas:authority "IUCN Global Standard for NbS" ;
    skos:definition "A material nature-based/resilience solution bearing a protective function." .

mas:DemandSignal a owl:Class ; rdfs:subClassOf obo:BFO_0000031 ;  # generically dependent continuant
    rdfs:label "Demand Signal" ;
    skos:definition "A registered federal demand signal. CONTEXT unless OBLIGATED (verify GovTribe)." .

mas:Investability a owl:Class ; rdfs:subClassOf obo:BFO_0000019 ; # quality
    rdfs:label "Investability" ; mas:authority "FIBO; ISO 31000" ;
    rdfs:seeAlso <https://spec.edmcouncil.org/fibo/> ;
    skos:definition "A quality of the asset: investable [Inv] vs recap-only [Fed]." .

mas:ExitValue a owl:Class ; rdfs:subClassOf obo:BFO_0000031 ;  # GDC (information/figure)
    rdfs:label "Exit Value" ; mas:authority "FIBO; deterministic IRR/NPV" ;
    rdfs:seeAlso <https://spec.edmcouncil.org/fibo/> ;
    skos:definition "The investor-facing exit-value figure the resilience thesis defends." .

##############################################################################
# OBJECT PROPERTIES (first-class relationships — the reuse-first house style)
##############################################################################
mas:hasCapability   a owl:ObjectProperty ; rdfs:domain mas:Asset ; rdfs:range mas:Capability .
mas:threatenedBy    a owl:ObjectProperty ; rdfs:domain mas:Asset ; rdfs:range mas:Hazard .
mas:locatedInSetting a owl:ObjectProperty ; rdfs:domain mas:Asset ;
    rdfs:comment "Range = a real ENVO environmental setting IRI." .
mas:providesService a owl:ObjectProperty ; rdfs:range mas:EcosystemService .
mas:mitigates       a owl:ObjectProperty ; rdfs:domain mas:NbS ; rdfs:range mas:Hazard .
mas:hasDemandSignal a owl:ObjectProperty ; rdfs:domain mas:Asset ; rdfs:range mas:DemandSignal .
mas:hasInvestability a owl:ObjectProperty ; rdfs:domain mas:Asset ; rdfs:range mas:Investability .
mas:hasRisk         a owl:ObjectProperty ; rdfs:domain mas:Asset .
mas:theme           a owl:DatatypeProperty .

##############################################################################
# ENVO settings used (REAL IRIs resolved via OLS4 — the live ecological reuse)
##############################################################################
obo:ENVO_00000045 rdfs:label "estuary" .              # OLS4 2026-07-04
obo:ENVO_00000889 rdfs:label "large river delta biome" .
obo:ENVO_00000022 rdfs:label "river" .
obo:ENVO_01001357 rdfs:label "desert" .
obo:ENVO_00000081 rdfs:label "mountain" .
obo:ENVO_01000180 rdfs:label "tundra biome" .
obo:ENVO_01001206 rdfs:label "grassland ecosystem" .

##############################################################################
# A-BOX — the 10 DIN sites (setting → real ENVO IRI); Austal + Mountain Pass detailed.
# All wasDerivedFrom the DIN site list (PROV-O lineage).
##############################################################################
ex:DIN_SiteList a prov:Entity ; rdfs:label "Real_Asset_Site_List_Draft_Network_v0_2 (List1/List2)" .

ex:austal_mobile a mas:Asset ; rdfs:label "Austal USA — Mobile, AL" ; mas:theme "Maritime" ;
    mas:locatedInSetting obo:ENVO_00000045 ;
    mas:hasCapability ex:cap_navy_shipbuilding ;
    mas:threatenedBy ex:hz_hurricane_surge, ex:hz_extreme_heat ;
    mas:hasInvestability ex:inv_investable ;
    prov:wasDerivedFrom ex:DIN_SiteList .
ex:cap_navy_shipbuilding a mas:Capability ; rdfs:label "Navy shipbuilding (LCS/EPF; maritime DIB)" .
ex:hz_hurricane_surge a mas:Hazard ; rdfs:label "hurricane surge" .
ex:hz_extreme_heat a mas:Hazard ; rdfs:label "extreme heat (>105F days)" .
ex:inv_investable a mas:Investability ; rdfs:label "[Inv] investable brownfield" .
ex:nbs_living_shoreline a mas:NbS ; rdfs:label "living shoreline / oyster reef" ;
    mas:mitigates ex:hz_hurricane_surge ; mas:providesService ex:svc_wave_attenuation .
ex:svc_wave_attenuation a mas:EcosystemService ; rdfs:label "wave attenuation" .

ex:mountain_pass a mas:Asset ; rdfs:label "Mountain Pass — CA (MP Materials)" ; mas:theme "Critical Minerals" ;
    mas:locatedInSetting obo:ENVO_01001357 ;
    mas:hasCapability ex:cap_ree_separation ;
    mas:threatenedBy ex:hz_water_scarcity, ex:hz_extreme_heat ;
    mas:hasInvestability ex:inv_investable ;
    prov:wasDerivedFrom ex:DIN_SiteList .
ex:cap_ree_separation a mas:Capability ; rdfs:label "REE mine + separation -> magnets (DIB supply chain)" .
ex:hz_water_scarcity a mas:Hazard ; rdfs:label "drought / water scarcity (processing constraint)" .

# Remaining 8 sites — setting linked to real ENVO IRIs (reuse covers all 10)
ex:tradepoint_baltimore a mas:Asset ; rdfs:label "Tradepoint Atlantic — Baltimore, MD" ; mas:theme "Maritime" ;
    mas:locatedInSetting obo:ENVO_00000045 ; prov:wasDerivedFrom ex:DIN_SiteList .   # Chesapeake estuary
ex:avondale_la a mas:Asset ; rdfs:label "Avondale Global Gateway — Avondale, LA" ; mas:theme "Maritime" ;
    mas:locatedInSetting obo:ENVO_00000889 ; prov:wasDerivedFrom ex:DIN_SiteList .   # lower-Mississippi delta
ex:philly_shipyard a mas:Asset ; rdfs:label "Philly Shipyard (Hanwha) — Philadelphia, PA" ; mas:theme "Maritime" ;
    mas:locatedInSetting obo:ENVO_00000022 ; prov:wasDerivedFrom ex:DIN_SiteList .   # tidal Delaware river
ex:stibnite a mas:Asset ; rdfs:label "Stibnite — Yellow Pine, ID (Perpetua)" ; mas:theme "Critical Minerals" ;
    mas:locatedInSetting obo:ENVO_00000081 ; prov:wasDerivedFrom ex:DIN_SiteList .   # mountain
ex:graphite_one a mas:Asset ; rdfs:label "Graphite One — Nome, AK" ; mas:theme "Critical Minerals" ;
    mas:locatedInSetting obo:ENVO_01000180 ; prov:wasDerivedFrom ex:DIN_SiteList .   # tundra biome
ex:round_top_stillwater a mas:Asset ; rdfs:label "Round Top / Stillwater — TX/OK (USA Rare Earth)" ; mas:theme "Critical Minerals" ;
    mas:locatedInSetting obo:ENVO_01001206 ; prov:wasDerivedFrom ex:DIN_SiteList ;   # grassland (Stillwater); Round Top is desert-edge
    rdfs:comment "Round Top (Sierra Blanca TX) is desert-edge (obo:ENVO_01001357); Stillwater OK is grassland." .
ex:crane_tmi a mas:Asset ; rdfs:label "Crane Clean Energy Ctr (TMI-1) — Londonderry Twp, PA" ; mas:theme "Energy" ;
    mas:locatedInSetting obo:ENVO_00000022 ; prov:wasDerivedFrom ex:DIN_SiteList .   # Susquehanna river
ex:palo_verde a mas:Asset ; rdfs:label "Palo Verde Nuclear — Tonopah, AZ" ; mas:theme "Energy" ;
    mas:locatedInSetting obo:ENVO_01001357 ; prov:wasDerivedFrom ex:DIN_SiteList .   # Sonoran desert
