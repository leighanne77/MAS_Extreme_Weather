        {
          "name": "Houston's Bayou Greenways Heat Mitigation",
          "location": "Houston, Texas",
          "description": "150 miles of forested trails reducing temperatures 7-12°F. Property values increased 15% within 500 feet. $100M investment yielding $480M in energy savings. Demonstrates strategic urban forest expansion targeting bayfront 'cooling corridors' with 65% canopy coverage, heat island mitigation in parking lots/commercial zones, and native shade trees selected for salt tolerance and hurricanes.",
          "scientific_evidence": {
            "temperature_reduction": "9°F cooling under tree canopy (Ziter et al., 2019 - Environmental Research Letters)",
            "property_values": "7% property value increase per 10% canopy coverage (Sander et al., 2020 - Landscape and Urban Planning)",
            "energy_savings": "25-30% reduction in cooling costs (Nowak et al., 2017 - Urban Forestry & Urban Greening)"
          },
          "economic_reports": {
