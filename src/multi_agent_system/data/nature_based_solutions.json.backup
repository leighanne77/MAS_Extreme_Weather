      "case_studies": [
        {
          "name": "Living Shorelines",
          "location": "Chesapeake Bay, Maryland/Virginia",
          "description": "Numerous living shoreline projects using native vegetation, oyster shells, and sometimes rock structures to stabilize shorelines, reduce erosion, and create habitat."
        },
        {
          "name": "Restore Coastal Alabama - Living Shorelines",
          "location": "Mobile Bay, Alabama (2010-present)",
          "description": "RESTORE Act funding drove living shoreline projects as part of ecosystem-based restoration and coastal buffering. Living shorelines act as natural breakwaters, dampening wave energy, reducing erosion during storms, and improving water quality. The project aims to restore 100 miles of reef and 1,000 acres of marsh, with impacts measured by partnering scientists."
        },
        {
          "name": "Port of San Diego Blue Economy Incubator - ECOncrete",
          "location": "Port of San Diego, California (~2016)",
          "description": "Launched pilot projects for ECOncrete (bio-enhancing shoreline armor) and sustainable aquaculture. Mobile should partner with this program to deploy ECOncrete along its industrial bulkheads to create living armor that restores habitat (oysters) while protecting the waterfront. Output Measured: Found 60+ species (invertebrates, fish) living on ECOncrete units, demonstrating dual use for habitat creation and shoreline protection.",
          "reference": "https://www.portofsandiego.org/press-releases/general-press-releases/port-san-diego-releases-sixth-edition-its-blue-economy"
        },
        {
          "name": "Pensacola Bay Living Shoreline",
          "location": "Pensacola Bay, Florida (2019-2021)",
          "description": "3.1 miles of oyster reef breakwaters installed offshore. Reduced erosion by 70%, increased property values 8%. Demonstrates effectiveness of graduated living shorelines combining oyster reef breakwaters positioned 50-100 feet offshore, salt marsh plantings (Spartina alterniflora) in intertidal zones, and submerged aquatic vegetation beds between reefs and shore.",
          "scientific_evidence": {
            "wave_attenuation": "Oyster reefs reduce wave heights by 85% (Wiberg et al., 2019 - Ecological Engineering)",
            "property_value_impact": "5-15% property value increases with living shorelines vs hardened structures (NOAA Technical Report, 2023)",
            "cost_benefit": "7:1 benefit-cost ratio for living shorelines (Bilkovic et al., 2021 - Virginia Institute of Marine Science)"
          },
          "economic_reports": {
            "wef": "World Economic Forum 'Nature Risk Rising' report values coastal wetlands at $23.2 billion/year globally for storm protection (WEF, 2020)",
            "goldman_sachs": "Goldman Sachs 'Taking Stock of Natural Capital' estimates living shorelines deliver 85% cost savings vs seawalls over 50 years (Goldman Sachs, 2022)"
          }
        },
        {
          "name": "Mobile Bay National Estuary Program - Lightning Point Restoration",
          "location": "Mobile Bay, Alabama",
          "description": "1.4 miles living shoreline restoration project. Demonstrated 91% wave reduction, providing effective storm protection while restoring natural habitat.",
