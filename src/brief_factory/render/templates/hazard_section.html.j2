<!doctype html>
<html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ doc_title }}</title>
<style>
  /* MAS document tokens */
  :root{--red:#C8202F;--gold:#E8A82A;--gold-ink:#8A640F;--blue:#4A6B8A;
        --navy:#1A2332;--cream:#F5EEE0;--muted:#5B6A72;--line:#D8DEE2;
        --display:'Oswald','Arial Narrow',Impact,sans-serif;
        --body:Arial,Helvetica,sans-serif;--data:'Courier New',Consolas,monospace}
  *{box-sizing:border-box}
  body{margin:0;background:#fff;color:var(--navy);font-family:var(--body);line-height:1.5}
  .topbar{background:var(--navy);border-bottom:4px solid var(--gold);padding:14px 34px;
          display:flex;justify-content:space-between;align-items:baseline}
  .topbar .word{font-family:var(--display);font-weight:700;font-size:26px;color:var(--cream)}
  .topbar .conf{font-family:var(--display);font-size:12px;letter-spacing:.22em;color:var(--gold)}
  main{max-width:1080px;margin:0 auto;padding:26px 34px 40px}
  h1{font-family:var(--display);font-weight:700;color:var(--red);font-size:30px;margin:0 0 4px}
  .rule{height:3px;width:170px;background:var(--gold);border-radius:2px;margin:8px 0 14px}
  .meta{color:var(--blue);font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase}
  h2{font-family:var(--body);font-weight:700;font-size:13px;letter-spacing:.06em;
     text-transform:uppercase;color:var(--blue);margin:26px 0 8px}
  table{border-collapse:collapse;width:100%;font-size:12.5px}
  th{background:var(--red);color:#fff;text-align:left;padding:7px 10px;font-size:11px;
     letter-spacing:.03em;text-transform:uppercase;white-space:nowrap}
  td{padding:7px 10px;border-top:1px solid var(--line);vertical-align:top}
  tbody tr:nth-child(even){background:var(--cream)}
  .num{font-family:var(--data);font-weight:700;white-space:nowrap}
  .pill{display:inline-block;font-family:var(--data);font-size:9.5px;font-weight:700;
        padding:2px 7px;border-radius:20px;letter-spacing:.02em;white-space:nowrap}
  .pill.nodata{background:#F7DADD;color:var(--red)}
  .pill.pref{background:#FBEFCF;color:var(--gold-ink)}
  .pill.role{background:#E7EDF2;color:var(--blue)}
  details.cite{display:inline}
  details.cite>summary{display:inline;cursor:pointer;color:var(--blue);font-size:10px;
        vertical-align:super;list-style:none}
  details.cite>summary::-webkit-details-marker{display:none}
  details.cite>div{position:absolute;z-index:5;max-width:430px;background:#fff;
        border:1px solid var(--line);border-left:4px solid var(--gold);border-radius:8px;
        padding:10px 13px;box-shadow:0 6px 18px rgba(26,35,50,.14);font-size:11.5px;line-height:1.5}
  details.cite a{color:var(--blue)}
  .caveat{background:var(--cream);border-left:4px solid var(--blue);border-radius:8px;
          padding:10px 14px;font-size:12px;margin:14px 0}
  footer{margin-top:26px;border-top:1px solid var(--line);padding-top:10px;
         color:var(--muted);font-size:11px}
  @media print{details.cite>div{position:static;box-shadow:none}}
</style></head>
<body>
<div class="topbar"><span class="word">MAS</span><span class="conf">MAS · {{ doc_type|upper }}</span></div>
<main>
  <h1>{{ doc_title }}</h1>
  <div class="rule"></div>
  <div class="meta">{{ block.hazard }} · site {{ block.site_id }}{% if as_of %} · as of {{ as_of }}{% endif %}</div>

  <h2>Gauge stations — exposure is a first-class choice</h2>
  <table>
    <thead><tr><th>Station</th><th>Name</th><th>Role</th><th>Record</th></tr></thead>
    <tbody>
    {% for s in block.stations %}
      <tr>
        <td class="num">{{ s.station_id }}</td>
        <td>{{ s.name }}</td>
        <td><span class="pill role">{{ s.exposure_role }}</span></td>
        <td>{% if s.record_end %}{{ s.record_start }} – <strong>{{ s.record_end }}</strong>{% elif s.record_start %}{{ s.record_start }} – active{% else %}active{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Observed peaks by event — storm tide (ft MLLW) · non-tidal residual (ft)</h2>
  <table>
    <thead><tr><th>Event</th>{% for s in block.stations %}<th>{{ s.station_id }}</th>{% endfor %}</tr></thead>
    <tbody>
    {% for ev in events %}
      <tr>
        <td>{{ ev }}</td>
        {% for s in block.stations %}
        {% set o = by_key[(s.station_id, ev)] %}
        <td>
          {% if o.status.value == 'reported-negative' %}
            <span class="pill nodata" title="{{ o.no_data_reason }}">NO DATA</span>
          {% else %}
            <span class="num">{{ o.peak_storm_tide.value }}</span> ·
            <span class="num">{{ o.peak_residual.value }}</span>
            <details class="cite"><summary>[src]</summary><div>
              <strong>{{ o.peak_residual.label }}</strong><br>
              {% for c in o.peak_residual.citations %}
                {{ c.source }} — <a href="{{ c.url }}">{{ c.url }}</a> (accessed {{ c.accessed }})
                <span class="pill pref">{{ c.preference.value }}</span>
                · continuity: {{ c.continuity.value }}<br>
              {% endfor %}
              {% if o.peak_residual.calc_trace %}
                <em>calc:</em> {{ o.peak_residual.calc_trace.formula }}<br>
                {% if o.peak_residual.calc_trace.method_note %}<em>{{ o.peak_residual.calc_trace.method_note }}</em>{% endif %}
              {% endif %}
            </div></details>
          {% endif %}
        </td>
        {% endfor %}
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if block.method_caveat %}
  <div class="caveat"><strong>Method caveat:</strong> {{ block.method_caveat }}</div>
  {% endif %}

  <footer>For decision support only — observed figures from cited gauges; no LLM in the numbers trust path;
  gaps are findings, never zeros. Generated by brief_factory (deterministic).</footer>
</main>
</body></html>
